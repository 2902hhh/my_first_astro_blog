---
import BaseLayout from '../layouts/BaseLayout.astro';
import GlassCard from '../components/GlassCard.astro';

const pageTitle = "丁焕";
const pageDescription = "Personal website of 丁焕.";

---

<BaseLayout pageTitle={pageTitle} pageDescription={pageDescription}>
  <!-- Hero / About combined card -->
  <section class="hero">
    <GlassCard>
      <div class="hero-inner">
        <img
          class="hero-avatar"
          src="/images/head.jpg"
          alt="丁焕"
          width="160"
          height="160"
        />
        <div class="hero-text">
          <h1 class="hero-name">丁焕</h1>
          <p style="margin-top: var(--space-md); color: var(--color-text-secondary);">
            本科生，目前在厦门求学。
          </p>
        </div>
      </div>
    </GlassCard>
  </section>

  <!-- Blog sections -->
  <section class="blog-grid">
    <a href="/tech" class="card-link">
      <GlassCard interactive>
        <h3 style="margin: 0 0 var(--space-sm); font-size: var(--text-lg);">
          <span class="glass-pill tech" style="margin-right: var(--space-sm);">技术</span>
          技术博客
        </h3>
        <p style="margin: 0; color: var(--color-text-secondary); font-size: var(--text-sm);">
          嵌入式、C/C++、Linux、ROS2 相关的学习笔记和项目记录。
        </p>
        <div style="margin-top: auto; padding-top: var(--space-md);">
          <span style="font-size: var(--text-sm); font-weight: 500; color: var(--color-accent);">浏览文章 →</span>
        </div>
      </GlassCard>
    </a>

    <a href="/life" class="card-link">
      <GlassCard interactive>
        <h3 style="margin: 0 0 var(--space-sm); font-size: var(--text-lg);">
          <span class="glass-pill life" style="margin-right: var(--space-sm);">生活</span>
          生活随笔
        </h3>
        <p style="margin: 0; color: var(--color-text-secondary); font-size: var(--text-sm);">
          日常感悟、摄影和生活中的零碎记录。
        </p>
        <div style="margin-top: auto; padding-top: var(--space-md);">
          <span style="font-size: var(--text-sm); font-weight: 500; color: var(--color-accent);">浏览随笔 →</span>
        </div>
      </GlassCard>
    </a>
  </section>
</BaseLayout>
