---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const allPosts = Object.values(
    import.meta.glob('../posts/*.md', { eager: true })
  );

  // Dynamically extract all unique tags from post frontmatter
  const allTags = new Set<string>();
  for (const post of allPosts as any[]) {
    const tags: string[] = post.frontmatter.tags || [];
    for (const tag of tags) {
      allTags.add(tag);
    }
  }

  return Array.from(allTags).map((tag) => ({
    params: { tag },
    props: { posts: allPosts, tag },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;

const filteredPosts = (posts as any[])
  .filter((post: any) => post.frontmatter.tags?.includes(tag))
  .sort((a: any, b: any) => {
    const dateA = new Date(a.frontmatter.pubDate).getTime();
    const dateB = new Date(b.frontmatter.pubDate).getTime();
    return dateB - dateA;
  });

const pageTitle = `Tag: ${tag}`;
const pageDescription = `Posts tagged with "${tag}"`;
---

<BaseLayout pageTitle={pageTitle} pageDescription={pageDescription}>
  <div class="page-content">
    <div class="page-header">
      <h1 style="text-transform: capitalize;">#{tag}</h1>
      <p>{filteredPosts.length} post{filteredPosts.length !== 1 ? 's' : ''} tagged with "{tag}"</p>
    </div>

    {
      filteredPosts.length > 0 ? (
        <ul class="post-list">
          {filteredPosts.map((post: any) => (
            <li class="post-list-item">
              <PostCard
                title={post.frontmatter.title}
                url={post.url}
                date={post.frontmatter.pubDate.toString().slice(0, 10)}
                description={post.frontmatter.description}
                author={post.frontmatter.author}
                tags={post.frontmatter.tags || []}
                category={post.frontmatter.category || 'tech'}
              />
            </li>
          ))}
        </ul>
      ) : (
        <div class="empty-state glass-card">
          <div class="empty-state-icon">🏷️</div>
          <p class="empty-state-text">No posts found with this tag.</p>
        </div>
      )
    }
  </div>
</BaseLayout>
