---
// Navigation.astro — Main navigation links
// Uses Astro.url to mark the current page as active
---

<div id="main-menu" class="nav-links">
  <a href="/" aria-current={Astro.url.pathname === '/' ? 'page' : undefined}>Home</a>
  <a href="/tech" aria-current={Astro.url.pathname.startsWith('/tech') ? 'page' : undefined}>技术博客</a>
  <a href="/life" aria-current={Astro.url.pathname.startsWith('/life') ? 'page' : undefined}>生活随笔</a>
</div>
